# CS Okey server — production environment (set these in Coolify → Environment Variables).
# Copy to .env for local dev. NEVER commit real secrets.

# REQUIRED in production. A long random secret: `openssl rand -hex 32`.
# Keep it STABLE across redeploys, or every reload forces a (silent) refresh.
JWT_SECRET=

# DB file on a PERSISTENT volume so users/sessions/games survive redeploys.
CS_OKEY_DB=/data/cs-okey.sqlite

# Comma-separated allow-list of web origins (the SPA). No wildcard with credentials.
ALLOWED_ORIGINS=https://okey.codesnap.nl

NODE_ENV=production
PORT=8787
LOG_LEVEL=info

# bcrypt work factor (>=12 recommended).
BCRYPT_COST=12

# First-boot admin password (seeds the 'admin' account once). Set a real secret;
# if unset, the server falls back to admin/admin and logs a warning (dev only).
ADMIN_PASSWORD=
# ADMIN_USERNAME=admin

# Delay between bot moves (ms) so clients see them play out.
BOT_DELAY_MS=600
